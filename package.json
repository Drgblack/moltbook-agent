{
  "name": "moltbook-supervised-poster",
  "version": "1.0.0",
  "private": true,
  "description": "Local-first supervised Moltbook posting tool for ZazaDraftAgent",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "post": "tsx src/index.ts",
    "post:dry": "tsx src/index.ts --dry-run",
    "post:api": "tsx src/index.ts --post-api",
    "autopost:once": "tsx src/index.ts --autopost-once",
    "home:api": "tsx src/index.ts --home-api",
    "import:docx": "tsx src/index.ts --import-docx",
    "generate:candidates": "tsx src/index.ts --generate-candidates",
    "import:generated": "tsx src/index.ts --import-generated",
    "review:candidates": "tsx src/index.ts --review-candidates",
    "agent:signup": "tsx src/index.ts --agent-signup",
    "agent:register": "tsx src/index.ts --agent-register",
    "agent:status": "tsx src/index.ts --agent-status",
    "feed:api": "tsx src/index.ts --feed-api",
    "reply:draft": "tsx src/index.ts --draft-reply",
    "list-posts": "tsx src/index.ts --list-posts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "mammoth": "^1.8.0",
    "playwright": "^1.52.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
